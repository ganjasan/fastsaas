<!doctype html>
<html lang="en">
<body style="font-family: system-ui, sans-serif; max-width: 560px; margin: 0 auto; padding: 24px;">
  <h1 style="font-size: 20px; font-weight: 600;">Sign in to {{ app_name }}</h1>
  <p>Use this single-use link to sign in:</p>
  <p>
    <a href="{{ url }}"
       style="display: inline-block; padding: 12px 20px; background: #111; color: #fff; text-decoration: none; border-radius: 6px;">
      Sign in
    </a>
  </p>
  <p style="color: #666; font-size: 14px;">
    Or copy this URL into your browser:<br>
    <a href="{{ url }}">{{ url }}</a>
  </p>
  <p style="color: #666; font-size: 14px;">Valid for 15 minutes; one-time use.</p>
  <p style="color: #999; font-size: 12px;">If you did not request a sign-in link, ignore this email — your account is safe.</p>
</body>
</html>
