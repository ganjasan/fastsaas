<!doctype html>
<html lang="en">
<body style="font-family: system-ui, sans-serif; max-width: 560px; margin: 0 auto; padding: 24px;">
  <h1 style="font-size: 20px; font-weight: 600;">Reset your {{ app_name }} password</h1>
  <p>Click the button below to choose a new password:</p>
  <p>
    <a href="{{ url }}"
       style="display: inline-block; padding: 12px 20px; background: #111; color: #fff; text-decoration: none; border-radius: 6px;">
      Reset password
    </a>
  </p>
  <p style="color: #666; font-size: 14px;">
    Or copy this URL into your browser:<br>
    <a href="{{ url }}">{{ url }}</a>
  </p>
  <p style="color: #666; font-size: 14px;">Valid for 1 hour; one-time use.</p>
  <p style="color: #999; font-size: 12px;">If you did not request a password reset, ignore this email — your password is unchanged.</p>
</body>
</html>
