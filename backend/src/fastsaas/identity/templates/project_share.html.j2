<!doctype html>
<html lang="en">
<body style="font-family: system-ui, sans-serif; max-width: 560px; margin: 0 auto; padding: 24px;">
  <h1 style="font-size: 20px; font-weight: 600;">A project was shared with you</h1>
  <p>
    <strong>{{ inviter_email }}</strong> has shared
    <strong>{{ project_name }}</strong> from
    <strong>{{ org_name }}</strong> with you on {{ app_name }}.
  </p>
  <p>
    <a href="{{ url }}"
       style="display: inline-block; padding: 12px 20px; background: #111; color: #fff; text-decoration: none; border-radius: 6px;">
      Open shared project
    </a>
  </p>
  <p style="color: #666; font-size: 14px;">
    Or copy this URL into your browser:<br>
    <a href="{{ url }}">{{ url }}</a>
  </p>
  <p style="color: #666; font-size: 14px;">
    The link is valid for {{ ttl_days }} days. You'll need an account on
    {{ app_name }} to view it — register first, then click the link.
  </p>
  <p style="color: #999; font-size: 12px;">If you don't recognise the sender, you can safely ignore this email.</p>
</body>
</html>
