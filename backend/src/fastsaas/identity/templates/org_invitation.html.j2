<!doctype html>
<html lang="en">
<body style="font-family: system-ui, sans-serif; max-width: 560px; margin: 0 auto; padding: 24px;">
  <h1 style="font-size: 20px; font-weight: 600;">You've been invited to {{ org_name }}</h1>
  <p>
    <strong>{{ inviter_email }}</strong> invited you to join
    <strong>{{ org_name }}</strong> on {{ app_name }}.
  </p>
  <p>
    <a href="{{ url }}"
       style="display: inline-block; padding: 12px 20px; background: #111; color: #fff; text-decoration: none; border-radius: 6px;">
      Accept invitation
    </a>
  </p>
  <p style="color: #666; font-size: 14px;">
    Or copy this URL into your browser:<br>
    <a href="{{ url }}">{{ url }}</a>
  </p>
  <p style="color: #666; font-size: 14px;">The link is valid for 7 days.</p>
  <p style="color: #999; font-size: 12px;">If you don't recognise the sender, you can safely ignore this email.</p>
</body>
</html>
