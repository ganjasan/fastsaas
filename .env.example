# Backend
ENV=dev
DATABASE_URL=postgresql+asyncpg://app_user:dev@localhost:5432/fastsaas
DATABASE_URL_MIGRATOR=postgresql+asyncpg://alembic_migrator:dev@localhost:5432/fastsaas
REDIS_URL=redis://localhost:6379/0

# SMTP — Mailhog in dev (no auth, plaintext on :1025)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@fastsaas.local

# Public-facing URL used to render magic-link / verification URLs in emails.
APP_URL=http://localhost:5173

# JWT signing — RS256 with rotatable kid (per ADR-008 §8a, design.md §D1, ADR-018).
# Defaults resolve to backend/infra/dev-secrets/jwt/dev-1.{pem,pub.pem} which
# ships in-repo as a DEV-ONLY keypair. Override absolute paths in prod.
JWT_SIGNING_KID=dev-1
# JWT_SIGNING_KEY_PATH=/run/secrets/jwt/dev-1.pem
# JWT_PUBLIC_KEYS_DIR=/run/secrets/jwt

# OAuth — leave blank in dev (the dev-bypass route covers manual flows).
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_MICROSOFT_CLIENT_ID=
OAUTH_MICROSOFT_CLIENT_SECRET=
OAUTH_MICROSOFT_TENANT=common

# When true, exposes /auth/oauth/dev/start?email=... that short-circuits the
# real provider round-trip. CI and local dev only — MUST be false in prod.
OAUTH_DEV_BYPASS=false

# Frontend (consumed by Vite)
VITE_API_BASE_URL=http://localhost:8000
